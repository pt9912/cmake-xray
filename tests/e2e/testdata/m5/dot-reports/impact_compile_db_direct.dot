digraph cmake_xray_impact {
  xray_report_type="impact";
  format_version=3;
  graph_node_limit=100;
  graph_edge_limit=200;
  graph_truncated=false;
  graph_target_graph_status="not_loaded";
  graph_impact_target_depth_requested=2;
  graph_impact_target_depth_effective=0;
  changed_file [kind="changed_file", label="app.cpp", path="/project/src/app.cpp"];
  direct_tu_1 [kind="translation_unit", impact="direct", label="app.cpp", path="/project/src/app.cpp", directory="/project/build", unique_key="/project/src/app.cpp|/project/build"];
  changed_file -> direct_tu_1 [kind="changed_file_direct_tu", style="solid"];
}
