digraph cmake_xray_impact {
  xray_report_type="impact";
  format_version=1;
  graph_node_limit=100;
  graph_edge_limit=200;
  graph_truncated=false;
  changed_file [kind="changed_file", label="shared.h", path="include/common/shared.h"];
  heuristic_tu_1 [kind="translation_unit", impact="heuristic", label="main.cpp", path="src/app/main.cpp", directory="build/app", unique_key="HOSTPATH"];
  heuristic_tu_2 [kind="translation_unit", impact="heuristic", label="core.cpp", path="src/lib/core.cpp", directory="build/lib", unique_key="HOSTPATH"];
  heuristic_tu_3 [kind="translation_unit", impact="heuristic", label="tool.cpp", path="src/tools/tool.cpp", directory="build/tools", unique_key="HOSTPATH"];
  changed_file -> heuristic_tu_1 [kind="changed_file_heuristic_tu", style="dashed"];
  changed_file -> heuristic_tu_2 [kind="changed_file_heuristic_tu", style="dashed"];
  changed_file -> heuristic_tu_3 [kind="changed_file_heuristic_tu", style="dashed"];
}
