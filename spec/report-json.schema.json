{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cmake-xray.example/report-json.schema.json",
  "title": "cmake-xray JSON report",
  "description": "Schema for cmake-xray analyze and impact JSON reports. See spec/report-json.md.",
  "oneOf": [
    {"$ref": "#/$defs/AnalysisReport"},
    {"$ref": "#/$defs/ImpactReport"}
  ],
  "$defs": {
    "FormatVersion": {
      "type": "integer",
      "const": 3
    },
    "TargetPriorityClass": {
      "type": "string",
      "enum": ["direct", "direct_dependent", "transitive_dependent"]
    },
    "TargetEvidenceStrength": {
      "type": "string",
      "enum": ["direct", "heuristic", "uncertain"]
    },
    "PrioritizedImpactedTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "priority_class", "graph_distance", "evidence_strength"],
      "properties": {
        "target": {"$ref": "#/$defs/TargetNode"},
        "priority_class": {"$ref": "#/$defs/TargetPriorityClass"},
        "graph_distance": {"type": "integer", "minimum": 0, "maximum": 32},
        "evidence_strength": {"$ref": "#/$defs/TargetEvidenceStrength"}
      }
    },
    "Severity": {
      "type": "string",
      "enum": ["note", "warning"]
    },
    "ObservationSource": {
      "type": "string",
      "enum": ["exact", "derived"]
    },
    "TargetMetadataStatus": {
      "type": "string",
      "enum": ["not_loaded", "loaded", "partial"]
    },
    "ReportInputSource": {
      "oneOf": [
        {"type": "string", "enum": ["cli"]},
        {"type": "null"}
      ]
    },
    "ChangedFileSource": {
      "type": "string",
      "enum": ["compile_database_directory", "file_api_source_root", "cli_absolute"]
    },
    "ImpactClassification": {
      "type": "string",
      "enum": ["direct", "heuristic", "uncertain"]
    },
    "Diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "message"],
      "properties": {
        "severity": {"$ref": "#/$defs/Severity"},
        "message": {"type": "string"}
      }
    },
    "DiagnosticArray": {
      "type": "array",
      "items": {"$ref": "#/$defs/Diagnostic"}
    },
    "TranslationUnitReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "directory"],
      "properties": {
        "source_path": {"type": "string"},
        "directory": {"type": "string"}
      }
    },
    "Target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "type"],
      "properties": {
        "display_name": {"type": "string"},
        "type": {"type": "string"}
      }
    },
    "TargetArray": {
      "type": "array",
      "items": {"$ref": "#/$defs/Target"}
    },
    "RankingMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arg_count", "include_path_count", "define_count", "score"],
      "properties": {
        "arg_count": {"type": "integer", "minimum": 0},
        "include_path_count": {"type": "integer", "minimum": 0},
        "define_count": {"type": "integer", "minimum": 0},
        "score": {"type": "integer", "minimum": 0}
      }
    },
    "RankingItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "reference", "metrics", "targets", "diagnostics"],
      "properties": {
        "rank": {"type": "integer", "minimum": 1},
        "reference": {"$ref": "#/$defs/TranslationUnitReference"},
        "metrics": {"$ref": "#/$defs/RankingMetrics"},
        "targets": {"$ref": "#/$defs/TargetArray"},
        "diagnostics": {"$ref": "#/$defs/DiagnosticArray"}
      }
    },
    "RankingContainer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limit", "total_count", "returned_count", "truncated", "items"],
      "properties": {
        "limit": {"type": "integer", "minimum": 0},
        "total_count": {"type": "integer", "minimum": 0},
        "returned_count": {"type": "integer", "minimum": 0},
        "truncated": {"type": "boolean"},
        "items": {
          "type": "array",
          "items": {"$ref": "#/$defs/RankingItem"}
        }
      }
    },
    "HotspotAffectedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "targets"],
      "properties": {
        "reference": {"$ref": "#/$defs/TranslationUnitReference"},
        "targets": {"$ref": "#/$defs/TargetArray"}
      }
    },
    "HotspotItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "header_path",
        "affected_total_count",
        "affected_returned_count",
        "affected_truncated",
        "affected_translation_units",
        "diagnostics"
      ],
      "properties": {
        "header_path": {"type": "string"},
        "affected_total_count": {"type": "integer", "minimum": 0},
        "affected_returned_count": {"type": "integer", "minimum": 0},
        "affected_truncated": {"type": "boolean"},
        "affected_translation_units": {
          "type": "array",
          "items": {"$ref": "#/$defs/HotspotAffectedItem"}
        },
        "diagnostics": {"$ref": "#/$defs/DiagnosticArray"}
      }
    },
    "HotspotContainer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limit", "total_count", "returned_count", "truncated", "items"],
      "properties": {
        "limit": {"type": "integer", "minimum": 0},
        "total_count": {"type": "integer", "minimum": 0},
        "returned_count": {"type": "integer", "minimum": 0},
        "truncated": {"type": "boolean"},
        "items": {
          "type": "array",
          "items": {"$ref": "#/$defs/HotspotItem"}
        }
      }
    },
    "ImpactedTranslationUnitItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "targets"],
      "properties": {
        "reference": {"$ref": "#/$defs/TranslationUnitReference"},
        "targets": {"$ref": "#/$defs/TargetArray"}
      }
    },
    "TargetGraphStatus": {
      "type": "string",
      "enum": ["not_loaded", "loaded", "partial"]
    },
    "TargetDependencyKind": {
      "type": "string",
      "enum": ["direct"]
    },
    "TargetDependencyResolution": {
      "type": "string",
      "enum": ["resolved", "external"]
    },
    "TargetNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "type", "unique_key"],
      "properties": {
        "display_name": {"type": "string"},
        "type": {"type": "string"},
        "unique_key": {"type": "string"}
      }
    },
    "TargetEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_display_name",
        "from_unique_key",
        "to_display_name",
        "to_unique_key",
        "kind",
        "resolution"
      ],
      "properties": {
        "from_display_name": {"type": "string"},
        "from_unique_key": {"type": "string"},
        "to_display_name": {"type": "string"},
        "to_unique_key": {"type": "string"},
        "kind": {"$ref": "#/$defs/TargetDependencyKind"},
        "resolution": {"$ref": "#/$defs/TargetDependencyResolution"}
      }
    },
    "TargetGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {"$ref": "#/$defs/TargetNode"}
        },
        "edges": {
          "type": "array",
          "items": {"$ref": "#/$defs/TargetEdge"}
        }
      }
    },
    "TargetHubsThresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in_threshold", "out_threshold"],
      "properties": {
        "in_threshold": {"type": "integer", "minimum": 0},
        "out_threshold": {"type": "integer", "minimum": 0}
      }
    },
    "TargetHubs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inbound", "outbound", "thresholds"],
      "properties": {
        "inbound": {
          "type": "array",
          "items": {"$ref": "#/$defs/TargetNode"}
        },
        "outbound": {
          "type": "array",
          "items": {"$ref": "#/$defs/TargetNode"}
        },
        "thresholds": {"$ref": "#/$defs/TargetHubsThresholds"}
      }
    },
    "AnalysisInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compile_database_path",
        "compile_database_source",
        "cmake_file_api_path",
        "cmake_file_api_resolved_path",
        "cmake_file_api_source"
      ],
      "properties": {
        "compile_database_path": {"type": ["string", "null"]},
        "compile_database_source": {"$ref": "#/$defs/ReportInputSource"},
        "cmake_file_api_path": {"type": ["string", "null"]},
        "cmake_file_api_resolved_path": {"type": ["string", "null"]},
        "cmake_file_api_source": {"$ref": "#/$defs/ReportInputSource"}
      }
    },
    "ImpactInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compile_database_path",
        "compile_database_source",
        "cmake_file_api_path",
        "cmake_file_api_resolved_path",
        "cmake_file_api_source",
        "changed_file",
        "changed_file_source"
      ],
      "properties": {
        "compile_database_path": {"type": ["string", "null"]},
        "compile_database_source": {"$ref": "#/$defs/ReportInputSource"},
        "cmake_file_api_path": {"type": ["string", "null"]},
        "cmake_file_api_resolved_path": {"type": ["string", "null"]},
        "cmake_file_api_source": {"$ref": "#/$defs/ReportInputSource"},
        "changed_file": {"type": "string"},
        "changed_file_source": {"$ref": "#/$defs/ChangedFileSource"}
      }
    },
    "AnalysisSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "translation_unit_count",
        "ranking_total_count",
        "hotspot_total_count",
        "top_limit",
        "include_analysis_heuristic",
        "observation_source",
        "target_metadata"
      ],
      "properties": {
        "translation_unit_count": {"type": "integer", "minimum": 0},
        "ranking_total_count": {"type": "integer", "minimum": 0},
        "hotspot_total_count": {"type": "integer", "minimum": 0},
        "top_limit": {"type": "integer", "minimum": 0},
        "include_analysis_heuristic": {"type": "boolean"},
        "observation_source": {"$ref": "#/$defs/ObservationSource"},
        "target_metadata": {"$ref": "#/$defs/TargetMetadataStatus"}
      }
    },
    "ImpactSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affected_translation_unit_count",
        "direct_translation_unit_count",
        "heuristic_translation_unit_count",
        "classification",
        "observation_source",
        "target_metadata",
        "affected_target_count",
        "direct_target_count",
        "heuristic_target_count"
      ],
      "properties": {
        "affected_translation_unit_count": {"type": "integer", "minimum": 0},
        "direct_translation_unit_count": {"type": "integer", "minimum": 0},
        "heuristic_translation_unit_count": {"type": "integer", "minimum": 0},
        "classification": {"$ref": "#/$defs/ImpactClassification"},
        "observation_source": {"$ref": "#/$defs/ObservationSource"},
        "target_metadata": {"$ref": "#/$defs/TargetMetadataStatus"},
        "affected_target_count": {"type": "integer", "minimum": 0},
        "direct_target_count": {"type": "integer", "minimum": 0},
        "heuristic_target_count": {"type": "integer", "minimum": 0}
      }
    },
    "AnalysisReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "format_version",
        "report_type",
        "inputs",
        "summary",
        "translation_unit_ranking",
        "include_hotspots",
        "target_graph_status",
        "target_graph",
        "target_hubs",
        "diagnostics"
      ],
      "properties": {
        "format": {"type": "string", "const": "cmake-xray.analysis"},
        "format_version": {"$ref": "#/$defs/FormatVersion"},
        "report_type": {"type": "string", "const": "analyze"},
        "inputs": {"$ref": "#/$defs/AnalysisInputs"},
        "summary": {"$ref": "#/$defs/AnalysisSummary"},
        "translation_unit_ranking": {"$ref": "#/$defs/RankingContainer"},
        "include_hotspots": {"$ref": "#/$defs/HotspotContainer"},
        "target_graph_status": {"$ref": "#/$defs/TargetGraphStatus"},
        "target_graph": {"$ref": "#/$defs/TargetGraph"},
        "target_hubs": {"$ref": "#/$defs/TargetHubs"},
        "diagnostics": {"$ref": "#/$defs/DiagnosticArray"}
      }
    },
    "ImpactReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "format_version",
        "report_type",
        "inputs",
        "summary",
        "directly_affected_translation_units",
        "heuristically_affected_translation_units",
        "directly_affected_targets",
        "heuristically_affected_targets",
        "target_graph_status",
        "target_graph",
        "prioritized_affected_targets",
        "impact_target_depth_requested",
        "impact_target_depth_effective",
        "diagnostics"
      ],
      "properties": {
        "format": {"type": "string", "const": "cmake-xray.impact"},
        "format_version": {"$ref": "#/$defs/FormatVersion"},
        "report_type": {"type": "string", "const": "impact"},
        "inputs": {"$ref": "#/$defs/ImpactInputs"},
        "summary": {"$ref": "#/$defs/ImpactSummary"},
        "directly_affected_translation_units": {
          "type": "array",
          "items": {"$ref": "#/$defs/ImpactedTranslationUnitItem"}
        },
        "heuristically_affected_translation_units": {
          "type": "array",
          "items": {"$ref": "#/$defs/ImpactedTranslationUnitItem"}
        },
        "directly_affected_targets": {"$ref": "#/$defs/TargetArray"},
        "heuristically_affected_targets": {"$ref": "#/$defs/TargetArray"},
        "target_graph_status": {"$ref": "#/$defs/TargetGraphStatus"},
        "target_graph": {"$ref": "#/$defs/TargetGraph"},
        "prioritized_affected_targets": {
          "type": "array",
          "items": {"$ref": "#/$defs/PrioritizedImpactedTarget"}
        },
        "impact_target_depth_requested": {
          "type": "integer",
          "minimum": 0,
          "maximum": 32
        },
        "impact_target_depth_effective": {
          "type": "integer",
          "minimum": 0,
          "maximum": 32
        },
        "diagnostics": {"$ref": "#/$defs/DiagnosticArray"}
      }
    }
  }
}
