digraph cmake_xray_impact {
  xray_report_type="impact";
  format_version=5;
  graph_node_limit=100;
  graph_edge_limit=200;
  graph_truncated=false;
  graph_target_graph_status="loaded";
  graph_impact_target_depth_requested=2;
  graph_impact_target_depth_effective=0;
  changed_file [kind="changed_file", label="config.h", path="include/common/config.h"];
  target_1 [kind="target", label="app", name="app", type="EXECUTABLE", unique_key="app::EXECUTABLE"];
  target_2 [kind="target", label="core", name="core", type="STATIC_LIBRARY", unique_key="core::STATIC_LIBRARY"];
}
