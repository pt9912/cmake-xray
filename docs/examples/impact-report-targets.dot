digraph cmake_xray_impact {
  xray_report_type="impact";
  format_version=2;
  graph_node_limit=100;
  graph_edge_limit=200;
  graph_truncated=false;
  graph_target_graph_status="loaded";
  changed_file [kind="changed_file", label="main.cpp", path="/project/src/main.cpp"];
  direct_tu_1 [kind="translation_unit", impact="direct", label="main.cpp", path="/project/src/main.cpp", directory="/project/build", unique_key="/project/src/main.cpp|/project/build"];
  target_1 [kind="target", impact="direct", label="app", name="app", type="EXECUTABLE", unique_key="app::EXECUTABLE"];
  target_2 [kind="target", label="iface", name="iface", type="INTERFACE_LIBRARY", unique_key="iface::INTERFACE_LIBRARY"];
  changed_file -> direct_tu_1 [kind="changed_file_direct_tu", style="solid"];
  direct_tu_1 -> target_1 [kind="direct_tu_target", style="solid"];
}
